# Copy to ingestion/.env and fill in — .env is gitignored, never commit real values.

# "local" (default) writes a CSV to ingestion/data/. "snowflake" loads into Snowflake.
INGEST_MODE=local

# Optional: comma-separated CoinGecko coin ids to fetch. Defaults to the curated
# set in config.py (top coins + stablecoins). Applies to both ingestion scripts.
# COIN_IDS=bitcoin,ethereum,tether,usd-coin

# Manual historical backfill start date (backfill_coingecko_history.py); end is run date.
# Keep within the last 365 days to stay on the keyless API.
HISTORY_START_DATE=2026-01-01

# Backfilling older than the last 365 days needs a PAID CoinGecko plan.
# Leave blank for the daily snapshot / short local tests (keyless works).
COINGECKO_API_KEY=
COINGECKO_API_PLAN=demo   # "demo" or "pro"; only "pro" unlocks full history

# Only needed when INGEST_MODE=snowflake
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=

# Auth: use EITHER a password OR a key pair (leave the others blank).
# CI reuses the DEVELOPER_SVC key pair; locally, pointing at the .p8 file is easiest.
SNOWFLAKE_PASSWORD=
# SNOWFLAKE_PRIVATE_KEY_PATH=../.keys/rsa_key.p8
# SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=

# DEVELOPER_SVC only has SYSADMIN/USERADMIN, not CRYPTO_PIPELINE_ROLE — use SYSADMIN
# when authenticating as it. A dedicated data user would use CRYPTO_PIPELINE_ROLE.
SNOWFLAKE_ROLE=SYSADMIN
SNOWFLAKE_WAREHOUSE=CRYPTO_WH
SNOWFLAKE_DATABASE=CRYPTO_DB
SNOWFLAKE_SCHEMA=STG
